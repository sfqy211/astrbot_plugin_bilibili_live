{
  "blivedm_web": {
    "description": "B站web接入",
    "type": "object",
    "items": {
      "enable": {
        "description": "是否启用",
        "type": "bool"
      },
      "cookie_str": {
        "description": "cookie",
        "type": "string"
      }
    }
  },
  "plugin_settings": {
    "description": "插件设置",
    "type": "object",
    "items": {
      "allow_message_type": {
        "description": "缓存的消息类型（用于手动触发 AI）",
        "type": "string",
        "default": "danmaku, super_chat",
        "hint": "danmaku=弹幕, gift=礼物, super_chat=醒目留言, like=点赞, enter_room=进场, guard_buy=上舰"
      },
      "filter_emoticon_only": {
        "description": "过滤纯表情弹幕（整条消息就是一个表情）",
        "type": "bool",
        "default": true
      },
      "buffer_size": {
        "description": "弹幕缓冲区大小（条数）",
        "type": "int",
        "default": 500
      },
      "http_server_port": {
        "description": "HTTP API 端口（0=随机，供 BiliDanmu 调用）",
        "type": "int",
        "default": 0
      },
      "random_drop": {
        "description": "随机丢弃",
        "type": "object",
        "items": {
          "enable": {
            "description": "是否启用",
            "type": "bool"
          },
          "drop_rate": {
            "description": "丢弃概率",
            "type": "float"
          }
        }
      }
    }
  }
}
