{
  "blivedm_web": {
    "description": "B站web接入",
    "type": "object",
    "items": {
      "enable": {
        "description": "是否启用",
        "type": "bool"
      },
      "room_id": {
        "description": "直播间ID",
        "type": "int"
      },
      "cookie_str": {
        "description": "cookie",
        "type": "string"
      }
    }
  },
  "plugin_settings": {
    "description": "插件设置",
    "type": "object",
    "items": {
      "allow_message_type": {
        "description": "允许的消息类型，以英文半角逗号分隔",
        "type": "string",
        "hint": "danmaku, gift, guard_buy, super_chat, like, enter_room"
      },
      "llm_chat_max_context": {
        "description": "LLM 聊天最大上下文长度(*2)",
        "type": "int",
        "default": 15
      },
      "llm_chat_callback": {
        "description": "LLM 聊天回调",
        "type": "object",
        "items": {
          "callback_url": {
            "description": "回调地址",
            "type": "string"
          },
          "callback_method": {
            "description": "回调方法",
            "type": "string",
            "options": ["GET", "POST"]
          }
        }
      },
      "http_server_port": {
        "description": "HTTP API 端口（0=随机，供 BiliDanmu 调用）",
        "type": "int",
        "default": 0
      },
      "random_drop": {
        "description": "随机丢弃",
        "type": "object",
        "items": {
          "enable": {
            "description": "是否启用",
            "type": "bool"
          },
          "drop_rate": {
            "description": "丢弃概率",
            "type": "float"
          }
        }
      }
    }
  }
}
